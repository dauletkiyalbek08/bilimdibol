# =============================================================
# bilimdibol — пример переменных окружения
# Скопируйте в .env.local и заполните при подключении.
# Без значений платформа работает в demo / mock mode.
# НЕ коммитьте реальные секреты.
# =============================================================

# ---- App ----
NEXT_PUBLIC_APP_URL=

# ---- Telegram уведомления о лидах ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Cron (авто-уход) — опционально, для защиты cron-маршрута ----
CRON_SECRET=

# ---- DeepSeek (AI-анализ звонков, в т.ч. казахский) ----
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ---- Meta (Facebook / Instagram / CAPI) ----
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=bilimdibol-demo-verify-token
META_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
IG_BUSINESS_ACCOUNT_ID=

# ---- WhatsApp Cloud API ----
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ---- Supabase (черновик схемы в supabase/schema.sql) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
